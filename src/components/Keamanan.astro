---
import SectionHeader from './SectionHeader.astro';
import SecurityItem from './SecurityItem.astro';
---

<section class="flex flex-col lg:flex-row items-start lg:items-center py-24 lg:py-[100px] px-6 lg:px-20 gap-12 lg:gap-20 bg-white">
  <!-- Left side -->
  <div class="flex flex-col gap-6 lg:w-1/2">
    <SectionHeader
      label="Kepercayaan"
      heading="Pembeli terlindungi. Penjual terjamin. Paylink yang menjaga keduanya."
      align="left"
    />
  </div>

  <!-- Right side -->
  <div class="flex flex-col gap-4 lg:w-1/2">
    <SecurityItem
      title="Dana pembeli aman."
      description="Selama transaksi berlangsung, dana tersimpan di sistem pembayaran berlisensi — bukan di rekening penjual. Tidak bisa disentuh siapapun sampai barang benar-benar sampai di tangan pembeli."
      iconPath='<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>'
    />
    <SecurityItem
      title="Ada mekanisme komplain."
      description="Barang tidak sesuai? Pembeli punya waktu untuk mengajukan komplain sebelum dana dilepas ke penjual."
      iconPath='<circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>'
    />
    <SecurityItem
      title="Untuk pembeli — tanpa aplikasi, tanpa ribet."
      description="Semua notifikasi transaksi dikirim langsung ke WhatsApp pembeli."
      iconPath='<path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/>'
    />
  </div>
</section>
