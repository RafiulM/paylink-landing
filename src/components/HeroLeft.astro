---
---

<div class="flex flex-col gap-8 w-full lg:w-[540px] shrink-0">
  <!-- Badge -->
  <div class="self-start flex items-center gap-2 rounded-2xl border border-badge-border bg-primary-light px-[18px] py-2.5">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1B6E3D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      <path d="m9 12 2 2 4-4"/>
    </svg>
    <span class="text-[11px] font-body font-bold uppercase tracking-[0.1em] text-primary">
      Rekening Bersama Otomatis
    </span>
  </div>

  <!-- Headline -->
  <div>
    <h1 class="text-[48px] lg:text-[64px] leading-[1.03] font-heading font-extrabold tracking-[-0.04em]">
      <span class="text-primary">Transaksi aman,</span><br />
      <span class="text-text-primary">dana cair saat barang diterima.</span>
    </h1>
  </div>

  <!-- Subtitle -->
  <p class="text-[17px] leading-7 font-body text-text-secondary max-w-[440px]">
    Paylink menahan dana pembeli sampai barang benar-benar diterima. Tidak ada lagi penipuan atau risiko bagi pembeli.
  </p>

  <!-- Buttons -->
  <div class="flex items-center gap-4 flex-wrap">
    <a
      href="https://app.paylink.co.id"
      class="flex items-center justify-center gap-2.5 rounded-full bg-primary px-9 py-[18px] text-[15px] font-heading font-bold text-white hover:bg-primary/90 transition-colors"
    >
      Mulai Transaksi Sekarang
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </a>
    <a
      href="#cara-kerja"
      class="flex items-center justify-center rounded-full border-[1.5px] border-border px-9 py-[18px] text-[15px] font-heading font-bold text-text-primary hover:bg-white/60 transition-colors"
    >
      Cara Kerja
    </a>
  </div>

  <!-- Stats -->
  <div class="flex items-center gap-6">
    <div class="flex flex-col">
      <span class="text-2xl leading-[30px] font-heading font-extrabold text-text-primary">100%</span>
      <span class="text-[10px] leading-3 font-body font-semibold uppercase tracking-[0.1em] text-text-secondary">Aman & Terjamin</span>
    </div>
    <div class="w-px h-9 bg-border"></div>
    <div class="flex flex-col">
      <span class="text-2xl leading-[30px] font-heading font-extrabold text-text-primary">Rp0</span>
      <span class="text-[10px] leading-3 font-body font-semibold uppercase tracking-[0.1em] text-text-secondary">Biaya Registrasi</span>
    </div>
  </div>
</div>
