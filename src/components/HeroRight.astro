<style>
  .hero-msg, .hero-card, .hero-step {
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .hero-msg {
    transform: translateY(16px);
  }
  .hero-card {
    transform: scale(0.95) translateY(12px);
  }
  .hero-step {
    transform: translateY(-8px);
  }
  .hero-msg.visible, .hero-card.visible, .hero-step.visible {
    opacity: 1 !important;
    transform: translateY(0) scale(1);
  }
  .hero-progress-bar {
    transition: width 0.8s ease 0.3s;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function initHeroFlow() {
    const flow = document.getElementById('hero-flow');
    if (!flow) return;

    // Desktop: staggered entrance animation
    const elements = flow.querySelectorAll<HTMLElement>('.hero-msg, .hero-card, .hero-step');
    const progressBar = flow.querySelector<HTMLElement>('.hero-progress-bar');
    let animated = false;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !animated) {
          animated = true;
          elements.forEach((el) => {
            const delay = parseInt(el.dataset.delay || '0', 10);
            setTimeout(() => el.classList.add('visible'), delay);
          });
          if (progressBar) {
            setTimeout(() => { progressBar.style.width = '65%'; }, 2800);
          }
        }
      });
    }, { threshold: 0.15 });

    observer.observe(flow);

    // Mobile: snap slider dots sync
    const slider = document.getElementById('mobile-slider');
    const dots = document.querySelectorAll<HTMLElement>('#slider-dots button');
    if (!slider || !dots.length) return;

    function updateDots(activeIndex: number) {
      dots.forEach((dot, i) => {
        if (i === activeIndex) {
          dot.classList.remove('w-1.5', 'bg-border');
          dot.classList.add('w-6', 'bg-primary');
        } else {
          dot.classList.add('w-1.5', 'bg-border');
          dot.classList.remove('w-6', 'bg-primary');
        }
      });
    }

    // Detect which slide is active on scroll
    let scrollTimeout: ReturnType<typeof setTimeout>;
    slider.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const scrollLeft = slider.scrollLeft;
        const slideWidth = slider.firstElementChild?.getBoundingClientRect().width || 0;
        const gap = 16;
        const activeIndex = Math.round(scrollLeft / (slideWidth + gap));
        updateDots(Math.min(activeIndex, 2));
      }, 50);
    });

    // Click dots to scroll
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        const slideWidth = slider.firstElementChild?.getBoundingClientRect().width || 0;
        const gap = 16;
        slider.scrollTo({ left: i * (slideWidth + gap), behavior: 'smooth' });
      });
    });
  }

  initHeroFlow();
  document.addEventListener('astro:page-load', initHeroFlow);
</script>
