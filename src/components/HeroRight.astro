<style>
  .hero-msg, .hero-card, .hero-step {
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .hero-msg {
    transform: translateY(16px);
  }
  .hero-card {
    transform: scale(0.95) translateY(12px);
  }
  .hero-step {
    transform: translateY(-8px);
  }
  .hero-msg.visible, .hero-card.visible, .hero-step.visible {
    opacity: 1 !important;
    transform: translateY(0) scale(1);
  }
  .hero-progress-bar {
    transition: width 0.8s ease 0.3s;
  }
</style>

<script>
  function initHeroFlow() {
    const flow = document.getElementById('hero-flow');
    if (!flow) return;

    // Desktop: staggered entrance animation
    const elements = flow.querySelectorAll<HTMLElement>('.hero-msg, .hero-card, .hero-step');
    const progressBar = flow.querySelector<HTMLElement>('.hero-progress-bar');
    let animated = false;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !animated) {
          animated = true;
          elements.forEach((el) => {
            const delay = parseInt(el.dataset.delay || '0', 10);
            setTimeout(() => el.classList.add('visible'), delay);
          });
          if (progressBar) {
            setTimeout(() => { progressBar.style.width = '65%'; }, 2800);
          }
        }
      });
    }, { threshold: 0.15 });

    observer.observe(flow);

    // Mobile: one-at-a-time slider
    const slider = document.getElementById('mobile-slider');
    const track = document.getElementById('mobile-slider-track');
    const dots = document.querySelectorAll<HTMLElement>('#slider-dots button');
    const mobileSteps = document.querySelectorAll<HTMLElement>('#mobile-steps .mobile-step');
    const progressLine = document.getElementById('mobile-steps-progress');
    if (!slider || !track || !dots.length) return;

    let currentSlide = 0;
    const totalSlides = 3;

    function goToSlide(index: number) {
      currentSlide = Math.max(0, Math.min(index, totalSlides - 1));
      track.style.transform = `translateX(-${currentSlide * 100}%)`;

      // Update dots
      dots.forEach((dot, i) => {
        if (i === currentSlide) {
          dot.classList.remove('w-1.5', 'bg-border');
          dot.classList.add('w-6', 'bg-primary');
        } else {
          dot.classList.add('w-1.5', 'bg-border');
          dot.classList.remove('w-6', 'bg-primary');
        }
      });

      // Update mobile step indicators
      mobileSteps.forEach((step, i) => {
        const circle = step.querySelector('.mobile-step-circle');
        const label = step.querySelector('.mobile-step-label');
        if (!circle || !label) return;

        if (i <= currentSlide) {
          circle.classList.remove('bg-border');
          circle.classList.add('bg-primary');
          label.classList.remove('text-text-secondary');
          label.classList.add('text-text-primary');
        } else {
          circle.classList.add('bg-border');
          circle.classList.remove('bg-primary');
          label.classList.add('text-text-secondary');
          label.classList.remove('text-text-primary');
        }
      });

      // Update progress line
      if (progressLine) {
        const percent = currentSlide === 0 ? 0 : currentSlide === 1 ? 50 : 100;
        progressLine.style.width = `${percent}%`;
      }
    }

    // Click dots to navigate
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => goToSlide(i));
    });

    // Auto-slide every 3s, loops back to first
    let autoSlideTimer = setInterval(() => {
      goToSlide((currentSlide + 1) % totalSlides);
    }, 3000);

    function resetAutoSlide() {
      clearInterval(autoSlideTimer);
      autoSlideTimer = setInterval(() => {
        goToSlide((currentSlide + 1) % totalSlides);
      }, 3000);
    }

    // Click dots resets auto-slide timer
    dots.forEach((dot, i) => {
      dot.addEventListener('click', resetAutoSlide);
    });

    // Touch swipe support
    let touchStartX = 0;
    let touchEndX = 0;

    slider.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    slider.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) goToSlide(currentSlide + 1);
        else goToSlide(currentSlide - 1);
        resetAutoSlide();
      }
    }, { passive: true });
  }

  initHeroFlow();
  document.addEventListener('astro:page-load', initHeroFlow);
</script>
