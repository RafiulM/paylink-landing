---
import BentoCard from './BentoCard.astro';
---

<div class="flex flex-col gap-5 w-full max-w-[1280px]">
  <!-- Row 1: VA (large) + QRIS (small) -->
  <div class="flex flex-col lg:flex-row gap-5">
    <BentoCard
      title="Virtual Account"
      description="Transfer bank via VA unik per transaksi. Semua bank besar didukung — BCA, BNI, Mandiri, BRI, dan lainnya."
      class="lg:w-[64%] shrink-0"
    >
      <!-- VA Illustration -->
      <div class="bg-surface rounded-2xl border border-border/60 p-5 w-full max-w-[380px]">
        <div class="flex items-center justify-between mb-4">
          <div class="w-10 h-10 bg-primary-light rounded-lg flex items-center justify-center">
            <svg width="20" height="14" viewBox="0 0 20 14" fill="none">
              <rect width="20" height="14" rx="2" fill="#1B6E3D"/>
              <line x1="0" y1="4" x2="20" y2="4" stroke="white" stroke-width="2"/>
              <line x1="0" y1="8" x2="20" y2="8" stroke="white" stroke-opacity="0.3" stroke-width="1"/>
            </svg>
          </div>
          <div class="w-9 h-6 rounded bg-border/60"></div>
        </div>
        <div class="text-xl font-heading font-extrabold tracking-[0.15em] text-text-primary mb-2">8810 0012 3456</div>
        <div class="text-[11px] font-body text-text-secondary">Bank Central Asia · Virtual Account</div>
      </div>
    </BentoCard>

    <BentoCard
      title="QRIS"
      description="Scan QR — berlaku untuk semua e-wallet dan m-banking di Indonesia."
      class="flex-1"
    >
      <!-- QRIS Illustration (animated) -->
      <div class="w-[140px] h-[140px] grid grid-cols-7 grid-rows-7 gap-[3px] p-2" id="qris-grid">
        {Array.from({ length: 49 }).map((_, i) => {
          const row = Math.floor(i / 7);
          const col = i % 7;
          const isCorner = (row < 3 && col < 3) || (row < 3 && col > 3) || (row > 3 && col < 3);
          const isCenter = row === 3 && col === 3;
          return (
            <div
              class:list={[
                "rounded-sm transition-colors duration-500",
                isCorner ? "bg-primary/80" : isCenter ? "bg-primary" : "bg-primary/20",
              ]}
              data-fixed={isCorner || isCenter ? "true" : undefined}
            />
          );
        })}
      </div>
    </BentoCard>
  </div>

  <!-- Row 2: E-Wallet (small) + Hold Dana (large, green) -->
  <div class="flex flex-col lg:flex-row gap-5">
    <BentoCard
      title="E-Wallet"
      description="Bayar langsung dari GoPay, OVO, atau DANA tanpa pindah aplikasi."
      class="lg:w-[36%] shrink-0"
    >
      <!-- E-Wallet badges -->
      <div class="flex items-center gap-3">
        <div class="bg-primary-light rounded-full px-4 py-2 border border-badge-border">
          <span class="text-xs font-heading font-bold text-primary">GoPay</span>
        </div>
        <div class="bg-primary-light rounded-full px-4 py-2 border border-badge-border">
          <span class="text-xs font-heading font-bold text-primary">OVO</span>
        </div>
        <div class="bg-primary-light rounded-full px-4 py-2 border border-badge-border">
          <span class="text-xs font-heading font-bold text-primary">DANA</span>
        </div>
      </div>
    </BentoCard>

    <BentoCard
      title="Hold Dana Otomatis"
      description="Dana pembeli ditahan aman di payment gateway berlisensi hingga barang dikonfirmasi diterima. Uang tidak pernah menyentuh PayLink."
      variant="green"
      class="flex-1"
    >
      <!-- Hold Dana diagram -->
      <div class="flex items-center justify-center gap-3">
        <div class="bg-white/15 rounded-xl px-4 py-3 text-center">
          <div class="text-[9px] text-white/50 mb-0.5">Pembeli</div>
          <div class="text-sm font-heading font-bold text-white">Rp 8.5jt</div>
        </div>
        <div class="flex items-center gap-1 text-white/30">
          <span class="text-xs">···</span>
        </div>
        <div class="w-12 h-12 rounded-full bg-white/15 flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <div class="flex items-center gap-1 text-white/30">
          <span class="text-xs">···</span>
        </div>
        <div class="bg-white/15 rounded-xl px-4 py-3 text-center">
          <div class="text-[9px] text-white/50 mb-0.5">Penjual</div>
          <div class="text-sm font-heading font-bold text-white">Rp 8.5jt</div>
        </div>
      </div>
    </BentoCard>
  </div>

  <!-- Row 3: Notifikasi WA + Disbursement (equal) -->
  <div class="flex flex-col lg:flex-row gap-5">
    <BentoCard
      title="Notifikasi WhatsApp"
      description="Update status di setiap tahap — pembayaran, pengiriman, dan pencairan dana langsung via WA."
      class="flex-1"
    >
      <!-- WA Notification mockup -->
      <div class="space-y-2.5 w-full max-w-[320px]">
        <div class="flex items-center gap-2 bg-surface rounded-xl p-3 border border-border/60">
          <div class="w-5 h-5 rounded-full bg-primary-light flex items-center justify-center shrink-0">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1B6E3D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          </div>
          <div class="flex-1 h-2.5 bg-border/60 rounded-full"></div>
          <div class="w-5 h-5 rounded-full bg-primary flex items-center justify-center text-[8px] font-bold text-white">2</div>
        </div>
        <div class="flex items-center gap-2 bg-surface rounded-xl p-3 border border-border/60 ml-4">
          <div class="w-5 h-5 rounded-full bg-primary-light flex items-center justify-center shrink-0">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1B6E3D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          </div>
          <div class="flex-1 h-2.5 bg-border/60 rounded-full"></div>
        </div>
      </div>
    </BentoCard>

    <BentoCard
      title="Disbursement Otomatis"
      description="Setelah konfirmasi, dana langsung transfer ke rekening penjual. Cepat dan tanpa ribet."
      class="flex-1"
    >
      <!-- Disbursement flow -->
      <div class="flex items-center justify-center gap-3">
        <div class="bg-primary-light rounded-xl px-3 py-2.5 text-center border border-badge-border">
          <div class="text-[9px] text-text-secondary mb-0.5">PayLink</div>
          <div class="text-sm font-heading font-bold text-primary">Rp 8.4jt</div>
        </div>
        <div class="flex items-center gap-0.5 text-text-secondary">
          <span class="text-[10px]">- - - -</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </div>
        <div class="bg-surface rounded-xl px-3 py-2.5 text-center border border-border/60">
          <div class="text-[9px] text-text-secondary mb-0.5">Penjual</div>
          <div class="text-sm font-heading font-bold text-text-primary">BCA</div>
        </div>
        <div class="w-5 h-5 rounded-full bg-primary flex items-center justify-center">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        </div>
      </div>
    </BentoCard>
  </div>
</div>

<script>
  function initQrisAnimation() {
    const grid = document.getElementById('qris-grid');
    if (!grid) return;

    const cells = Array.from(grid.children) as HTMLElement[];
    const animatable = cells.filter(c => !c.dataset.fixed);

    function randomize() {
      animatable.forEach(cell => {
        const highlight = Math.random() < 0.35;
        if (highlight) {
          cell.classList.remove('bg-primary/20');
          cell.classList.add('bg-primary/80');
        } else {
          cell.classList.remove('bg-primary/80');
          cell.classList.add('bg-primary/20');
        }
      });
    }

    setInterval(randomize, 800);
  }

  initQrisAnimation();
  document.addEventListener('astro:page-load', initQrisAnimation);
</script>
