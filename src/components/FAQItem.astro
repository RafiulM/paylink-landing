---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<div class="flex flex-col gap-3 py-7 border-t border-border">
  <h3 class="text-[17px] leading-[22px] font-heading font-bold text-text-primary">{question}</h3>
  <p class="text-sm leading-[22px] font-body text-text-secondary">{answer}</p>
</div>
