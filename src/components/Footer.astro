---
import Logo from './Logo.astro';
---

<footer class="flex flex-col pt-[60px] px-6 lg:px-20 pb-10 gap-10 bg-[#1A1A18]">
  <!-- Top section -->
  <div class="flex flex-col lg:flex-row justify-between gap-10">
    <!-- Logo & description -->
    <div class="flex flex-col gap-4 max-w-[320px]">
      <Logo variant="light" />
      <p class="text-sm leading-[22px] font-body text-white/50">
        Rekening bersama otomatis untuk transaksi jual-beli C2C di media sosial.
      </p>
    </div>

    <!-- Link columns -->
    <div class="flex flex-wrap gap-16 lg:gap-20">
      <div class="flex flex-col gap-4">
        <span class="text-[13px] font-body font-semibold uppercase tracking-[0.05em] text-white/40">Produk</span>
        <a href="#cara-kerja" class="text-sm font-body text-white/70 hover:text-white transition-colors">Cara Kerja</a>
        <a href="#fitur" class="text-sm font-body text-white/70 hover:text-white transition-colors">Fitur</a>
        <a href="#faq" class="text-sm font-body text-white/70 hover:text-white transition-colors">FAQ</a>
      </div>
      <div class="flex flex-col gap-4">
        <span class="text-[13px] font-body font-semibold uppercase tracking-[0.05em] text-white/40">Perusahaan</span>
        <a href="#" class="text-sm font-body text-white/70 hover:text-white transition-colors">Tentang Kami</a>
        <a href="#" class="text-sm font-body text-white/70 hover:text-white transition-colors">Kontak</a>
        <a href="/kebijakan-privasi" class="text-sm font-body text-white/70 hover:text-white transition-colors">Kebijakan Privasi</a>
        <a href="/syarat-ketentuan" class="text-sm font-body text-white/70 hover:text-white transition-colors">Syarat & Ketentuan</a>
      </div>
      <div class="flex flex-col gap-4">
        <span class="text-[13px] font-body font-semibold uppercase tracking-[0.05em] text-white/40">Hubungi</span>
        <a href="#" class="text-sm font-body text-white/70 hover:text-white transition-colors">WhatsApp</a>
        <a href="#" class="text-sm font-body text-white/70 hover:text-white transition-colors">Instagram</a>
        <a href="#" class="text-sm font-body text-white/70 hover:text-white transition-colors">Email</a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="flex flex-col sm:flex-row justify-between gap-2 pt-6 border-t border-white/10">
    <span class="text-[13px] font-body text-white/35">PT Paylink Digital Nusantara · Kediri, Indonesia</span>
    <span class="text-[13px] font-body text-white/35">2026 PayLink. All rights reserved.</span>
  </div>
</footer>
