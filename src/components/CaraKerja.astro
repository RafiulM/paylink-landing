---
import StepCard from './StepCard.astro';
---

<section id="cara-kerja" class="flex flex-col items-center py-24 lg:py-[100px] px-6 lg:px-20 bg-white">
  <div class="w-full max-w-[1280px] flex flex-col gap-14">
    <!-- Heading + subtitle -->
    <div class="max-w-[640px] text-center self-center">
      <span class="text-[13px] leading-4 font-body font-semibold uppercase tracking-[0.1em] text-primary mb-4 block">
        Cara Kerja
      </span>
      <h2 class="text-[36px] lg:text-[44px] leading-[1.12] font-heading font-extrabold tracking-[-0.03em] text-text-primary mb-5">
        Sudah transfer duluan, tapi barang tidak kunjung datang?
      </h2>
      <p class="text-[17px] leading-[28px] font-body text-text-secondary">
        Ribuan orang mengalami hal yang sama setiap hari. Paylink menjamin uang Anda aman — tiga langkah, semua pihak terlindungi.
      </p>
    </div>

    <!-- Step cards -->
    <div class="flex flex-col md:flex-row gap-5 w-full">
      <StepCard
        number="01"
        title="Buat link transaksi"
        description="Penjual atau pembeli buat order escrow di Paylink — isi nama barang dan harga. Selesai dalam hitungan detik."
        iconPath='<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>'
      />
      <StepCard
        number="02"
        title="Dana ditahan di pihak netral"
        description="Pembeli bayar via VA, QRIS, atau e-wallet. Dana tidak masuk ke rekening penjual — disimpan aman sampai barang tiba."
        iconPath='<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>'
      />
      <StepCard
        number="03"
        title="Barang sampai, dana cair otomatis"
        description="Setelah pembeli konfirmasi penerimaan, dana langsung dikirim ke rekening penjual. Tidak perlu menunggu, tidak perlu followup manual."
        iconPath='<line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>'
      />
    </div>
  </div>
</section>
